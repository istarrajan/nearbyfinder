# No API keys are required for OpenStreetMap / Overpass.
# Optional: override the Overpass endpoint used by the server proxy (default: overpass-api.de).
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Google Analytics (gtag). Defaults to G-LE6KW57JBT. Override or set empty to turn off scripts.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
