# No API keys are required for OpenStreetMap / Overpass.
# Optional: override the Overpass endpoint used by the server proxy (default: overpass-api.de).
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# Public site URL (embedded in default Overpass User-Agent only; do not set Referer unless you know you need it).
# NEXT_PUBLIC_APP_URL=https://nearbyfinder.vercel.app
# Optional explicit User-Agent for Overpass upstream requests.
# OVERPASS_USER_AGENT=MyApp/1.0 (+https://example.com)
# Rare: only if your Overpass instance requires a browser-style Referer (public overpass-api.de often returns 406 with Referer on server scripts).
# OVERPASS_REFERER=https://example.com/

# Google Analytics (gtag). Defaults to G-LE6KW57JBT. Override or set empty to turn off scripts.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
